<UserControl x:Class="Suivi_Elec_Maison.PrixElecView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F3">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,12">
            <Button x:Name="BtnRefresh" Height="30" Padding="12,0">↻  Actualiser</Button>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <DataGrid x:Name="DataGridPrixElec"
                      AutoGenerateColumns="True" IsReadOnly="True"
                      BorderThickness="0" RowBackground="Transparent"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"/>
        </Border>
    </Grid>
</UserControl>