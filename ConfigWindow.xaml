<Window x:Class="Suivi_Elec_Maison.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuration" Height="350" Width="480">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
            <Label Width="120">Host:</Label>
            <TextBox x:Name="TxtHost" Width="300" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,8">
            <Label Width="120">Port:</Label>
            <TextBox x:Name="TxtPort" Width="300" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,0,0,8">
            <Label Width="120">Username:</Label>
            <TextBox x:Name="TxtUsername" Width="300" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="3" Margin="0,0,0,8">
            <Label Width="120">Password:</Label>
            <PasswordBox x:Name="TxtPassword" Width="300" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="4" Margin="0,0,0,8">
            <Label Width="120">Database:</Label>
            <TextBox x:Name="TxtDatabase" Width="300" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="5" Margin="0,0,0,8">
            <Label Width="120">SSL Mode:</Label>
            <ComboBox x:Name="CbSslMode" Width="180" Height="26">
                <ComboBoxItem>Require</ComboBoxItem>
                <ComboBoxItem>Prefer</ComboBoxItem>
                <ComboBoxItem>Disable</ComboBoxItem>
                <ComboBoxItem>VerifyFull</ComboBoxItem>
            </ComboBox>
          <CheckBox x:Name="ChkTrustServerCert" Content="Trust Server Certificate" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="6" HorizontalAlignment="Left" VerticalAlignment="bottom" Margin="0,10,0,0">
            <Button x:Name="BtnTest" Width="100" Height="30" Margin="0,0,10,0">Tester</Button>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <RadioButton x:Name="RbEncrypted" IsChecked="True" Margin="0,0,8,0">Chiffré</RadioButton>
                <RadioButton x:Name="RbPlain">En clair</RadioButton>
            </StackPanel>
            <Button x:Name="BtnSave" Width="140" Height="30" Margin="10,0,0,0">Enregistrer</Button>
        </StackPanel>
    </Grid>
</Window>
