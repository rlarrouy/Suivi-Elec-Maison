<Window x:Class="Suivi_Elec_Maison.MeasurementsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mesures" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8" HorizontalAlignment="Left">
            <Button x:Name="BtnRefresh" Width="100" Height="28" Margin="0,0,8,0">Actualiser</Button>
            <TextBlock VerticalAlignment="Center" Margin="8,0,4,0">Mois :</TextBlock>
            <ComboBox x:Name="CbMonth" Width="140" Height="26" VerticalAlignment="Center" />
        </StackPanel>

        <DataGrid x:Name="DataGridMeasures" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
    </Grid>
</Window>