<Window x:Class="Suivi_Elec_Maison.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Suivi Élec Maison" Height="860" Width="1200"
        MinHeight="600" MinWidth="900"
        Background="#F5F5F3">
    <Window.Resources>
        <!-- Style item nav normal -->
        <Style x:Key="NavItem" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"   Value="#8C8C8A"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Height"       Value="36"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"      Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="#28282A"/>
                                <Setter Property="Foreground" Value="#D8D8D6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style item nav actif -->
        <Style x:Key="NavItemActive" TargetType="Button" BasedOn="{StaticResource NavItem}">
            <Setter Property="Background"  Value="#1A3D2E"/>
            <Setter Property="Foreground"  Value="#5DCAA5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ SIDEBAR ══ -->
        <Grid Grid.Column="0" Background="#1E1E1E">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo -->
            <StackPanel Grid.Row="0" Margin="16,20,16,16">
                <Border Background="#1D9E75" CornerRadius="8" Width="32" Height="32"
                        HorizontalAlignment="Left" Margin="0,0,0,8">
                    <TextBlock Text="⚡" FontSize="16" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Suivi Élec" FontSize="13" FontWeight="Medium"
                           Foreground="#FFFFFF"/>
                <TextBlock Text="Maison" FontSize="11" Foreground="#555553"/>
            </StackPanel>

            <!-- Navigation -->
            <StackPanel Grid.Row="1" Margin="8,0">
                <!-- Section Données -->
                <TextBlock Text="DONNÉES" FontSize="10" Foreground="#3A3A38"
                           Margin="10,8,0,4" FontWeight="Medium"/>
                <Button x:Name="BtnNavDashboard" Style="{StaticResource NavItemActive}"
                        Click="Nav_Click" Tag="Dashboard">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="▦" FontSize="14" Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Tableau de bord" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnNavMesures" Style="{StaticResource NavItem}"
                        Click="Nav_Click" Tag="Mesures">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="≡" FontSize="16" Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Mesures" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnNavComparaison" Style="{StaticResource NavItem}"
                        Click="Nav_Click" Tag="Comparaison">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⇄" FontSize="14" Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Comparaison" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Section Saisie -->
                <TextBlock Text="SAISIE" FontSize="10" Foreground="#3A3A38"
                           Margin="10,12,0,4" FontWeight="Medium"/>
                <Button x:Name="BtnNavSaisie" Style="{StaticResource NavItem}"
                        Click="Nav_Click" Tag="Saisie">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="✎" FontSize="14" Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Saisir mesure" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnNavPrixElec" Style="{StaticResource NavItem}"
                        Click="Nav_Click" Tag="PrixElec">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="€" FontSize="14" Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Prix élec" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Section Système -->
                <TextBlock Text="SYSTÈME" FontSize="10" Foreground="#3A3A38"
                           Margin="10,12,0,4" FontWeight="Medium"/>
                <Button x:Name="BtnNavConfig" Style="{StaticResource NavItem}"
                        Click="Nav_Click" Tag="Config">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚙" FontSize="14" Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Configuration" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Footer connexion -->
            <Border Grid.Row="2" BorderBrush="#2A2A28" BorderThickness="0,1,0,0"
                    Padding="16,10">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="6" Height="6" Fill="#1D9E75"
                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="TxtDbStatus" Text="PostgreSQL · connecté"
                               FontSize="11" Foreground="#555553"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ ZONE CONTENU ══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Topbar -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="#E0E0DE" BorderThickness="0,0,0,0.5">
                <DockPanel Margin="20,0">
                    <TextBlock x:Name="TxtPageTitle"
                               Text="Tableau de bord"
                               FontSize="14" FontWeight="Medium"
                               Foreground="#1A1A1A"
                               VerticalAlignment="Center"
                               DockPanel.Dock="Left"/>
                </DockPanel>
            </Border>

            <!-- ContentControl — zone d'affichage des vues -->
            <ContentControl x:Name="MainContent" Grid.Row="1"/>
        </Grid>
    </Grid>
</Window>