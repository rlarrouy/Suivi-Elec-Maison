<Window x:Class="Suivi_Elec_Maison.AddMeasureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Saisie de mesure" Height="520" Width="460"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Ligne date + recherche ── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <DatePicker x:Name="DpJour" Width="180" Height="30"
                        SelectedDate="{x:Static system:DateTime.Today}"
                        xmlns:system="clr-namespace:System;assembly=mscorlib"/>
            <Button x:Name="BtnSearch" Width="110" Height="30" Margin="8,0,0,0"
                    Click="BtnSearch_Click">🔍 Rechercher</Button>
        </StackPanel>

        <!-- ── Bandeau alerte doublon ── -->
        <Border x:Name="PanelAlert" Grid.Row="1" Visibility="Collapsed"
                Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="1"
                CornerRadius="4" Padding="8,6" Margin="0,0,0,10">
            <TextBlock x:Name="TxtAlert" FontSize="12" Foreground="#856404"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- ── Onglets ── -->
        <TabControl x:Name="TabMain" Grid.Row="2" Margin="0,0,0,10"
                    SelectionChanged="TabMain_SelectionChanged">
            <TabItem x:Name="TabNew" Header="Nouvelle mesure">
                <StackPanel Margin="0,10,0,0">
                    <TextBlock FontSize="12" Foreground="Gray" FontStyle="Italic"
                               Margin="0,0,0,8">Aucune mesure trouvée pour cette date.</TextBlock>
                </StackPanel>
            </TabItem>
            <TabItem x:Name="TabEdit" Header="Modifier la mesure existante" IsEnabled="False">
                <StackPanel Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock FontSize="12" Foreground="Gray">ID mesure :</TextBlock>
                        <TextBlock x:Name="TxtIdMesure" FontSize="12" FontWeight="Bold"
                                   Margin="6,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- ── Formulaire commun ── -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="165"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ID Prix Élec -->
            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                       Margin="0,0,0,8" FontSize="13">ID Prix Élec :</TextBlock>
            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBox x:Name="TxtIdPrixElec" Width="55" Height="26" IsReadOnly="True"
                         Background="#F0F0F0" VerticalContentAlignment="Center" FontSize="13"/>
                <TextBlock x:Name="TxtPrixElecInfo" VerticalAlignment="Center"
                           Margin="8,0,0,0" Foreground="Gray" FontStyle="Italic" FontSize="12"/>
            </StackPanel>

            <!-- Production -->
            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                       Margin="0,0,0,8" FontSize="13">Production (kWh) :</TextBlock>
            <TextBox x:Name="TxtProduction" Grid.Row="1" Grid.Column="1"
                     Height="26" Margin="0,0,0,8" VerticalContentAlignment="Center" FontSize="13"/>

            <!-- Stockage -->
            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                       Margin="0,0,0,8" FontSize="13">Stockage (kWh) :</TextBlock>
            <TextBox x:Name="TxtStockage" Grid.Row="2" Grid.Column="1"
                     Height="26" Margin="0,0,0,8" VerticalContentAlignment="Center" FontSize="13"/>

            <!-- Autoconsommation -->
            <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"
                       Margin="0,0,0,8" FontSize="13">Autoconsommation (kWh) :</TextBlock>
            <TextBox x:Name="TxtAutoconsommation" Grid.Row="3" Grid.Column="1"
                     Height="26" Margin="0,0,0,8" VerticalContentAlignment="Center" FontSize="13"/>

            <!-- Conso Batterie -->
            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"
                       Margin="0,0,0,8" FontSize="13">Conso Batterie (kWh) :</TextBlock>
            <TextBox x:Name="TxtConsoBatterie" Grid.Row="4" Grid.Column="1"
                     Height="26" Margin="0,0,0,8" VerticalContentAlignment="Center" FontSize="13"/>

            <!-- Conso Réseau -->
            <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center"
                       Margin="0,0,0,8" FontSize="13">Conso Réseau (kWh) :</TextBlock>
            <TextBox x:Name="TxtConsoReseau" Grid.Row="5" Grid.Column="1"
                     Height="26" Margin="0,0,0,8" VerticalContentAlignment="Center" FontSize="13"/>

            <!-- Conso Totale -->
            <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center"
                       Margin="0,0,0,0" FontSize="13">Conso Totale (kWh) :</TextBlock>
            <TextBox x:Name="TxtConsoTotale" Grid.Row="6" Grid.Column="1"
                     Height="26" Margin="0,0,0,0" VerticalContentAlignment="Center" FontSize="13"/>
        </Grid>

        <!-- ── Boutons ── -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="BtnSave" Width="120" Height="30" Margin="0,0,8,0"
                    IsEnabled="False" Click="BtnSave_Click">Enregistrer</Button>
            <Button x:Name="BtnCancel" Width="100" Height="30"
                    Click="BtnCancel_Click">Annuler</Button>
        </StackPanel>
    </Grid>
</Window>