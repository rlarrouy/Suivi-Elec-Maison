<Window x:Class="Suivi_Elec_Maison.AddMeasureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Saisie d'une mesure" Height="420" Width="420"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Jour -->
        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10">Date de la mesure :</TextBlock>
        <DatePicker x:Name="DpJour" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10"
                    SelectedDateChanged="DpJour_SelectedDateChanged"/>

        <!-- Id Prix Elec (auto) -->
        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10">ID Prix Élec :</TextBlock>
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="TxtIdPrixElec" Width="60" Height="26" IsReadOnly="True"
                     Background="#F0F0F0" VerticalContentAlignment="Center"/>
            <TextBlock x:Name="TxtPrixElecInfo" VerticalAlignment="Center"
                       Margin="8,0,0,0" Foreground="Gray" FontStyle="Italic"/>
        </StackPanel>

        <!-- Production -->
        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10">Production (kWh) :</TextBlock>
        <TextBox x:Name="TxtProduction" Grid.Row="2" Grid.Column="1" Height="26"
                 Margin="0,0,0,10" VerticalContentAlignment="Center"/>

        <!-- Stockage -->
        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10">Stockage (kWh) :</TextBlock>
        <TextBox x:Name="TxtStockage" Grid.Row="3" Grid.Column="1" Height="26"
                 Margin="0,0,0,10" VerticalContentAlignment="Center"/>

        <!-- Autoconsommation -->
        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10">Autoconsommation (kWh) :</TextBlock>
        <TextBox x:Name="TxtAutoconsommation" Grid.Row="4" Grid.Column="1" Height="26"
                 Margin="0,0,0,10" VerticalContentAlignment="Center"/>

        <!-- Conso Batterie -->
        <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10">Conso Batterie (kWh) :</TextBlock>
        <TextBox x:Name="TxtConsoBatterie" Grid.Row="5" Grid.Column="1" Height="26"
                 Margin="0,0,0,10" VerticalContentAlignment="Center"/>

        <!-- Conso Réseau -->
        <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10">Conso Réseau (kWh) :</TextBlock>
        <TextBox x:Name="TxtConsoReseau" Grid.Row="6" Grid.Column="1" Height="26"
                 Margin="0,0,0,10" VerticalContentAlignment="Center"/>

        <!-- Conso Totale -->
        <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10">Conso Totale (kWh) :</TextBlock>
        <TextBox x:Name="TxtConsoTotale" Grid.Row="7" Grid.Column="1" Height="26"
                 Margin="0,0,0,10" VerticalContentAlignment="Center"/>

        <!-- Boutons -->
        <StackPanel Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnSave" Width="100" Height="30" Margin="0,0,8,0"
                    Click="BtnSave_Click">Enregistrer</Button>
            <Button x:Name="BtnCancel" Width="100" Height="30"
                    Click="BtnCancel_Click">Annuler</Button>
        </StackPanel>
    </Grid>
</Window>